(globalThis.TURBOPACK||(globalThis.TURBOPACK=[])).push(["object"==typeof document?document.currentScript:void 0,65148,e=>{"use strict";var i,t,a=e.i(17035),n=e.i(81045),o=e.i(76366),r=e.i(6827),s=e.i(25366),l=e.i(56560),c=e.i(58009),d=e.i(95056),u=e.i(9327),p=e.i(19637),h=e.i(23240),m=e.i(78340),x=e.i(60555);e.i(56605);var g=e.i(98639);let f=n.default.forwardRef(function({children:e,size:t=16,...a},o){return n.default.createElement(g.default,{width:t,height:t,ref:o,xmlns:"http://www.w3.org/2000/svg",viewBox:"0 0 32 32",fill:"currentColor",...a},i||(i=n.default.createElement("path",{d:"M29.53,6.15a1,1,0,0,0-1,0L20,10.38V7a1,1,0,0,0-1.45-.89L10,10.38V3A1,1,0,0,0,9,2H3A1,1,0,0,0,2,3V28H30V7A1,1,0,0,0,29.53,6.15ZM22,26H18V19h4Zm6,0H24V18a1,1,0,0,0-1-1H17a1,1,0,0,0-1,1v8H4V4H8v9.62l10-5v5l10-5Z"})),e)});var y=e.i(37979),v=e.i(44780),b=e.i(86244),w=e.i(78225),N=e.i(22650),j=e.i(24367);let z=n.default.forwardRef(function({children:e,size:i=16,...a},o){return n.default.createElement(g.default,{width:i,height:i,ref:o,xmlns:"http://www.w3.org/2000/svg",viewBox:"0 0 32 32",fill:"currentColor",...a},t||(t=n.default.createElement("path",{d:"M25,2A11.01,11.01,0,0,0,14.7549,9.0244,6.9939,6.9939,0,0,0,9,6H6V9a7.0078,7.0078,0,0,0,7,7h1v9.0493a9.9229,9.9229,0,0,0-6.071,2.8794l1.414,1.4141a8,8,0,0,1,12.3086,1.2134l1.6616-1.1128A9.98,9.98,0,0,0,16,25.062V16h1A11.0125,11.0125,0,0,0,28,5V2ZM13,14A5.0057,5.0057,0,0,1,8,9V8H9a5.0054,5.0054,0,0,1,5,5v1ZM26,5a9.01,9.01,0,0,1-9,9H16V13a9.01,9.01,0,0,1,9-9h1Z"})),e)});var S=e.i(32648),k=e.i(59970),T=e.i(52197);let C=[{title:"Service Before Self",desc:"Leadership is a duty. Public office is a platform for responsibility, not privilege."},{title:"Institutional Strength",desc:"Sustainable progress depends on strong, independent institutions that outlast political cycles."},{title:"Productivity Based Prosperity",desc:"Economic growth must be driven by productivity, enterprise, innovation, and responsible private sector partnership."},{title:"Inclusive Opportunity",desc:"National development must benefit all regions and demographics without discrimination."},{title:"Transparency and Accountability",desc:"Public funds must be traceable, audited, and responsibly allocated."}],W=["The unity and preservation of the Nigerian nation, based on equality, justice, mutual respect, and equal protection of all groups within the Federal Republic of Nigeria.","A commitment to the development and protection of democracy and democratic institutions and values, i.e. the judiciary, the free and independent media, and respect for human rights.","A commitment to the observance of the Constitution, laws, and international treaties concerning democracy, human rights, the rule of law, and respect for the dignity of citizens.","To eradicate the fault lines of tribe, religion, ethnicity, and hatred that militate against the formation of a national identity, vision, and agenda.","To foster and strengthen national unity and peace founded on justice, equity, and respect for equal Nigerian citizenship.","To promote Pan-Africanism and African brotherhood, with Nigeria serving as a catalyst for African renaissance. Support for the Black race shall be a focus of our government. Investment in foreign policy must be increased and revised. Nigeria must align with nations that uphold mutual respect."],A=[{title:"Environmental Justice",icon:p.Earth,desc:"A Nigeria where the protection of the environment and its remediation is given topmost priority. A country where our natural resources are protected and equitably shared, ensuring clean air, water, and land for all generations. We commit to combating climate change, promoting renewable energy, and holding polluters accountable, so that no community suffers disproportionately from environmental degradation."},{title:"Upholding Human Rights",icon:y.UserMultiple,desc:"A Nigeria where dignity, freedom, and equality are non-negotiable. We pledge to safeguard the rights of every individual, regardless of ethnicity, religion, or background."},{title:"Security",icon:h.Security,desc:"The security of the human person and the investment in the individual, education and healthcare. We will prioritise the funding, reorganisation, strengthening, and strategic refocusing of all arms of Nigeria’s defence, intelligence, and security agencies. The protection of lives and property is the first and most fundamental responsibility of government. Every citizen has the right to expect and receive protection, support, and the assurance of safety in their homes, communities, and places of work."},{title:"Guided by the Rule of Law",icon:v.Policy,desc:"A Nigeria where justice is blind, transparent, and swift. We envision institutions that enforce laws impartially, eradicate corruption, and ensure accountability for all—from the highest offices to everyday citizens—creating a foundation of trust and stability that empowers democratic governance."},{title:"Empowering Youth and Women",icon:p.Events,desc:"A dynamic Nigeria led by the energy and innovation of its youth and the wisdom and resilience of its women. We commit to providing equal opportunities in education, leadership, and economic participation, breaking barriers to unleash their potential as drivers of national transformation."},{title:"Building Human Capacity",icon:b.Development,desc:"Where every Nigerian is equipped with the skills, knowledge, and resources to achieve their fullest potential. Through world-class education, vocational training, healthcare, and lifelong learning, we aim to cultivate a skilled workforce that propels Nigeria into a global leader in innovation, productivity, and self-reliance."}],q=[{title:"Education",icon:p.Education,color:"#3f4195",highlight:"Our guiding principle is simple: Education, and yet more education.",paragraphs:["We will place strong emphasis on education, skills development, and human capacity building as the cornerstone of Nigeria’s progress. We recognise that investing in our people is the greatest guarantee of a resilient economy, strengthened national security, and sustainable national development.","Through improved funding, policy reforms, and expanded access at all levels, we will build an education system that equips Nigerians with the knowledge, skills, and innovation required to compete globally and lead confidently into the future."]},{title:"National Security",icon:h.Security,color:"#ed3337",paragraphs:["National security will remain the foremost priority of our government. We will prioritise the funding, reorganisation, strengthening, and strategic refocusing of all arms of Nigeria’s defence, intelligence, and security agencies to ensure greater efficiency and effectiveness.","The protection of lives and property is the first and most fundamental responsibility of government. Every citizen has the right to expect and receive protection, support, and the assurance of safety in their homes, communities, and places of work. We are committed to upholding this duty without compromise."]},{title:"Quality and Affordable Healthcare",icon:m.Stethoscope,color:"#3f4195",paragraphs:["We will prioritise funding, training, and the provision of modern and affordable healthcare facilities, programmes, and policies that enable all Nigerians to access quality and affordable healthcare, while ensuring adequate welfare for healthcare workers."]},{title:"The Economy",icon:x.Finance,color:"#ed3337",paragraphs:["We are committed to a free market economy that encourages enterprise, innovation, and productivity. At the same time, we recognise the essential role of the state in providing strategic regulation and social protection.","We believe that government has a duty to safeguard its most vulnerable citizens and ensure that economic growth is inclusive and broadly shared. Through responsible oversight, targeted social programmes, and policies that expand opportunity, we will promote sustainable and equitable economic development for all Nigerians."]},{title:"Industrialisation",icon:f,color:"#3f4195",paragraphs:["We will promote and protect policies that advance industrialisation and the development of local technology and production to build a competitive economy, rather than depending on imported or foreign technology and expertise. Nigeria’s industrial production capacity must be deliberately supported and funded, and the transfer of technology must be actively encouraged.","All critical moribund industries must be revitalised for optimal productivity.","The disgraceful overdependence on foreign products and technology must be discouraged through appropriate policies that stimulate local production, technology, and enterprise, making Nigeria more self sufficient."]},{title:"Agriculture and Food Security",icon:w.CropGrowth,color:"#ed3337",paragraphs:["Priority attention will be given to achieving self sufficiency in agricultural production across the entire value chain. Nigeria’s abundant arable land and favourable climatic conditions must be fully utilised through the right policies, adequate funding, strategic incentives, and accessible credit facilities.","Special attention will be placed not only on crop cultivation but also on processing, storage, and distribution to reduce post harvest losses, create jobs, add value, and guarantee food security for domestic consumption and export.","We will also prioritise fisheries, aquaculture, and animal husbandry. In particular, we shall promote and support specialised training, the establishment of commercially viable ranches, and the development of modern farming environments to enhance productivity, ensure sustainability, and strengthen national food security."]},{title:"Women and Youth Inclusion",icon:N.Partnership,color:"#3f4195",paragraphs:["We are committed to building an inclusive society that guarantees the full participation of women and young people in governance, economic development, and nation building.","Recognising the vital role of women as leaders, professionals, entrepreneurs, and mothers, we will pursue deliberate and measurable affirmative action policies to ensure their meaningful representation and active involvement in the affairs of government at all levels. We believe that empowering women and youth is not only a matter of equity, but a strategic necessity for national development and sustainable progress."]},{title:"True Federalism",icon:j.Building,color:"#ed3337",paragraphs:["We are committed to a comprehensive review of the Nigerian Constitution and laws to guarantee true federalism and devolution of powers.","Our goal is to empower federating units to fully exercise their constitutional rights and responsibilities within the Nigerian federation. By promoting greater autonomy, accountability, and fiscal responsibility at the state and local levels, we will strengthen governance, encourage healthy competition, and foster balanced national development."]},{title:"The Environment",icon:z,color:"#3f4195",paragraphs:["We are committed to promoting a clean and sustainable environment through the eradication of pollution and the maintenance of international standards to preserve and protect our environment.","We will pursue and strengthen policies and laws to ensure that all companies operating in Nigeria, particularly in the oil and gas sector, strictly adhere to global best practices and environmental standards. These measures will safeguard the health, safety, and wellbeing of oil producing communities.","Furthermore, we will prioritise the remediation and restoration of environments that have been degraded and rendered unsafe by decades of oil related environmental pollution, ensuring accountability, justice for affected communities, and sustainable ecological recovery."]},{title:"Affordable Housing",icon:S.Home,color:"#ed3337",paragraphs:["The development of new towns and cities, and the provision of affordable housing for all strata of the Nigerian populace, will be prioritised.","Our growing population, particularly young people, will be supported through deliberate land and housing policies implemented in partnership with state and local governments, as well as the private sector.","We are committed to closing the housing deficit swiftly, ensuring that every Nigerian, especially young people, has the opportunity to own a modern and smart home. This policy, when aggressively pursued, will not only provide homes but also unlock economic growth, stimulate local production of building materials, and create millions of jobs, both directly and indirectly."]},{title:"Foreign Policy",icon:x.Globe,color:"#3f4195",paragraphs:["We will promote Pan Africanism and African brotherhood, positioning Nigeria as a catalyst for African renaissance, unity, and sustainable development across the continent.","Investment in foreign policy will be significantly increased, and its strategic direction revised to align Nigeria with nations that respect and support the principles of Pan Africanism, mutual cooperation, sovereignty, and shared prosperity. Our foreign policy will be guided by the protection of national interest, the advancement of economic diplomacy, and the strengthening of Nigeria’s leadership role in Africa and the global community."]},{title:"Culture and Heritage",icon:k.Theater,color:"#ed3337",paragraphs:["We are committed to promoting respect for Nigeria’s rich cultural diversity, history, and languages. Policies will be pursued to study, preserve, and celebrate our cultural heritage, ensuring that the traditions, values, and identities of all Nigerian communities are protected and passed on to future generations."]},{title:"National Infrastructure and Transportation",icon:k.TrainSpeed,color:"#3f4195",paragraphs:["We will pursue an aggressive drive to close Nigeria’s infrastructural gap, focusing on practical, strategic, and transformative projects rather than mere aesthetics.","Infrastructure development will be targeted at connecting the country, stimulating economic activity, and creating a competitive and virile economy. Special attention will be given to the mass movement of goods and people through the expansion and modernisation of rail, road, and water transport networks, including riverine and underserved areas. By improving connectivity, we will enhance trade, mobility, and access to opportunities for all Nigerians."]}],P=[{tier:"National",items:["National Convention","Central Working Committee","National Working Committee","Board of Trustees"]},{tier:"Zonal",items:["Zonal Congress","Zonal Working Committee"]},{tier:"State",items:["State Congress","State Working Committee","State Elders Council"]},{tier:"Senatorial",items:["Senatorial District Working Committee"]},{tier:"Local Government",items:["Local Government Congress","Local Government Working Committee","Local Government Caucus"]},{tier:"Ward",items:["Ward Congress","Ward Working Committee"]},{tier:"Grassroots",items:["Community Working Committee","Polling Unit Working Committee"]}];function O(){let[e,i]=(0,n.useState)(!1),t=(0,T.default)(.15),p=(0,n.useRef)(null),h=(0,n.useRef)(null);return((0,n.useEffect)(()=>{i(!0)},[]),(0,n.useEffect)(()=>{if(!e)return;r.gsap.registerPlugin(s.ScrollTrigger);let i=r.gsap.matchMedia();return i.add("(min-width: 1px)",()=>{if(p.current){let e=p.current.querySelector(".mv-line"),i=p.current.querySelector(".mv-label"),t=p.current.querySelector(".mv-heading"),a=p.current.querySelectorAll(".mv-highlight");r.gsap.timeline({scrollTrigger:{trigger:p.current,start:"top 80%",once:!0}}).fromTo(e,{scaleX:0},{scaleX:1,duration:.6,ease:"power3.out",transformOrigin:"left center"}).fromTo(i,{opacity:0,x:-20},{opacity:1,x:0,duration:.5,ease:"power2.out"},"-=0.3").fromTo(t,{opacity:0,y:40,clipPath:"inset(0 0 100% 0)"},{opacity:1,y:0,clipPath:"inset(0 0 0% 0)",duration:.8,ease:"power3.out"},"-=0.2").fromTo(a,{opacity:.3},{opacity:1,duration:.5,stagger:.15,ease:"power2.out"},"-=0.3")}if(h.current){let e=h.current,i=e.querySelector(".mv-watermark"),t